# Warranty Management System - Environment Variables
# Copy file nay thanh `.env` roi dieu chinh lai theo moi truong thuc te.

# ── Network Configuration ─────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# ── App Settings ──────────────────────────────────────────────────────────────
# Dat `DEBUG=True` cho local development, `False` cho moi truong nghiem ngat hon.
DEBUG=True

# Runtime database chinh: PostgreSQL
# Vi du:
# DATABASE_URL=postgresql://warranty_user:your_password@db-host:5432/warranty
DATABASE_URL=postgresql://warranty_user:change_me@localhost:5432/warranty

# SQLite fallback cho legacy/dev neu khong dung PostgreSQL.
# He thong se uu tien `DATABASE_URL` neu bien nay duoc set.
WARRANTY_DB=./apps/server/warranty.db

# ── Odoo Master Data ──────────────────────────────────────────────────────────
# Khai bao Odoo khi muon dong bo/search customer va product tu Odoo.
ODOO_BASE_URL=https://odoo.creta.vn
ODOO_DB=change_me
ODOO_USERNAME=change_me@example.com
ODOO_PASSWORD=change_me

# Co the giu mac dinh neu Odoo cua ban dung dung model chuan hien tai.
ODOO_CUSTOMER_MODEL=res.partner
ODOO_PRODUCT_MODEL=product.product
ODOO_TIMEOUT=15
