# Warranty Management System - Environment Variables
# Copy file này thành .env và chỉnh lại cho phù hợp môi trường

# ── Database ──────────────────────────────────────────────────────────────────
# Đường dẫn tuyệt đối đến file SQLite
# Windows:  WARRANTY_DB=D:/path/to/warranty/apps/server/warranty.db
# Linux:    WARRANTY_DB=/home/user/warranty/apps/server/warranty.db
WARRANTY_DB=apps/server/warranty.db

# ── Server ────────────────────────────────────────────────────────────────────
# Host và port cho uvicorn
HOST=0.0.0.0
PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
